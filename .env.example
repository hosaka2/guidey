# ============================================================
# Guidey 環境変数
# cp .env.example .env して必要箇所を編集
# ============================================================

# --- Backend: LLM ---
LLM_PROVIDER=ollama                    # "ollama" (default, free) or "anthropic"
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b                # 高速版 (リアルタイム判定)
OLLAMA_HQ_MODEL=gemma4:e2b            # 高品質版 (将来: gemma4:26b or Claude)

# --- Backend: Anthropic (optional) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Backend: API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# --- Backend: Storage ---
MILVUS_DB_PATH=./db/guidey.db
STATIC_DIR=./static

# --- Backend: Valkey (Redis互換, セッション管理) ---
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SEC=1800

# --- Backend: LangSmith (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_xxxxx
# LANGCHAIN_PROJECT=guidey

# --- Mobile ---
# EXPO_PUBLIC_API_URL=http://x.x.x.x:8000
