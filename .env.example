# LLM Provider: "ollama" (default, free) or "anthropic" (API cost)
LLM_PROVIDER=ollama

# Ollama (default - local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Anthropic (optional - for higher quality)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["*"]

# Milvus
MILVUS_DB_PATH=./db/guidey.db
